# =============================================================================
# .gitignore — CPS Cheque Processing System
# Covers: .NET 8 Web API + React 18 TypeScript SPA
# =============================================================================

# ── .NET ──────────────────────────────────────────────────────────────────────
bin/
obj/
*.user
*.suo
.vs/
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.opendb
*.VC.db

# EF Core migration snapshots are kept — only ignore local override files
# (migrations themselves should be committed)

# Published output
publish/
out/

# NuGet
*.nupkg
*.snupkg
.nuget/
packages/
project.lock.json
project.fragment.lock.json
artifacts/

# Rider / JetBrains
.idea/
*.sln.iml

# Logs
Logs/
*.log

# Production appsettings — NEVER commit real credentials
appsettings.Production.json
appsettings.*.local.json

# ── React / Node ───────────────────────────────────────────────────────────────
CPS.Frontend/node_modules/
CPS.Frontend/build/
CPS.Frontend/.env
CPS.Frontend/.env.local
CPS.Frontend/.env.development.local
CPS.Frontend/.env.test.local
CPS.Frontend/.env.production.local
CPS.Frontend/npm-debug.log*
CPS.Frontend/yarn-debug.log*
CPS.Frontend/yarn-error.log*

# ── .NET wwwroot (generated by React build — do not commit) ───────────────────
CPS.API/wwwroot/

# ── Image storage (outside project, but guard against accidental inclusion) ───
ChequeData/

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Misc ──────────────────────────────────────────────────────────────────────
*.bak
*.tmp
*.swp
*~
